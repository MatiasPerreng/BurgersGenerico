# Copiar a .env y completar.

DATABASE_URL=mysql+pymysql://root:1234@localhost/burgers

# Firma de los JWT (login admin/repartidor). Usá una cadena larga y aleatoria en producción.
JWT_SECRET_KEY=

# CORS (coma-separado). Incluí el origen del front (ej. http://localhost:5174)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
