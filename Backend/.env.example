DATABASE_URL=mysql+pymysql://usuario:clave@localhost/burgers

# --- Auth (staff admin / repartidor) ---
# Secreto largo y aleatorio para firmar JWT. En producción (ENV=production) es obligatorio.
JWT_SECRET_KEY=
# Duración del token de sesión en horas (por defecto 24).
JWT_EXPIRE_HOURS=24
# ENV=production exige JWT_SECRET_KEY definido.
# ENV=development

# Orígenes del front (Vite dev ~5174, vite preview ~4173). Separados por coma.
# Desde otra máquina/celular: agregá http://TU_IP:5174 (y :4173 si usás preview), p. ej.:
# http://186.48.75.154:5174,http://186.48.75.154:4173
#
# Opcional: en desarrollo, permitir el front desde cualquier host en los puertos típicos de Vite
# (evita listar cada IP). No uses esto en producción expuesta a Internet sin más controles.
# CORS_ORIGIN_REGEX=^https?://[^/]+:(5173|5174|5175|4173|4174)$
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173

# --- Mercado Pago (Checkout Pro + referencia automática) ---
#
# RECEPTOR (quien cobra — tu local / aplicación):
# - Panel: https://www.mercadopago.com.uy/developers/panel/app
# - Creá una aplicación (o usá una existente). El Access Token identifica al **vendedor** que recibe el pago.
# - Mientras desarrollás: pestaña "Credenciales" → modo **Prueba** → copiá el **Access Token** de prueba acá.
# - En producción: mismo lugar pero credenciales de **Producción** y cuenta MP real del negocio.
# - Sin MERCADOPAGO_ACCESS_TOKEN no hay Checkout Pro: el pago no se asocia solo al pedido (solo link de respaldo o ref/comprobante manual).
#
# QUIEN PAGA EN PRUEBA (comprador ficticio):
# - En Developers → tu aplicación → sección **Usuarios de prueba** (o "Cuentas de prueba").
# - Creá un usuario tipo **Comprador** (Buyer). MP te da email y contraseña.
# - Al redirigir a Mercado Pago para pagar, iniciá sesión con ese usuario comprador; pagás con saldo de prueba.
# - Alternativa: pagar con **tarjetas de prueba** que documenta MP (flujo tarjeta sin cuenta MP).
# - No mezcles: credenciales **de prueba** del receptor + usuarios/tarjetas **de prueba**. Producción va aparte.
#
# En el buscador del sitio de desarrolladores buscá "usuarios de prueba" y "tarjetas de prueba".
# Guía paso a paso (tarjeta ficticia + vista admin): Backend/docs/MERCADOPAGO_PRUEBAS.md
#
MERCADOPAGO_ACCESS_TOKEN=
#
# Link de cobro (solo si NO hay Access Token o falla la preferencia): redirección de respaldo.
# Con MERCADOPAGO_ACCESS_TOKEN el flujo normal es Checkout Pro: el pago queda ligado al pedido al volver
# de MP (sin que el cliente cargue el n°). Si no definís MERCADOPAGO_LINK_PAGO, en fallback se usa el
# link La Buena Vida. Para desactivar el fallback: MERCADOPAGO_LINK_PAGO=checkout_pro
MERCADOPAGO_LINK_PAGO=
# Public Key (APP_USR-...) — opcional en el backend; el checkout Pro solo usa el Access Token arriba.
# Si usás Bricks/SDK en el front, también podés poner la misma clave como VITE_MERCADOPAGO_PUBLIC_KEY.
MERCADOPAGO_PUBLIC_KEY=
# URL pública del front para volver después de pagar (back_urls). DEBE ser el mismo host:puerto
# donde abrís la web (Vite en Frontend/Burgers/vite.config.js usa 5174 por defecto).
# Si entrás por IP pública: PUBLIC_FRONTEND_URL=http://186.48.75.154:5174
PUBLIC_FRONTEND_URL=http://localhost:5174
# URL pública del API (webhook). En local usá ngrok/cloudflare: https://xxxx.ngrok.io
# Si está vacío, no se envía notification_url (igual podés sincronizar al volver con payment_id).
BACKEND_PUBLIC_URL=
# Host del sitio de Actividades (detalle del cobro vendedor). Uruguay por defecto.
# MERCADOPAGO_ACTIVITIES_HOST=www.mercadopago.com.uy
# Opcional: misma clave en ?s=... del webhook para rechazar POSTs ajenos.
MERCADOPAGO_WEBHOOK_SECRET=
